{
  "name": "gotrack",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.gocloud.gotrack",
    "productName": "GoTrack",
    "win": {
      "target": "nsis",
      "icon": "logo_GoCloud.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!node_modules/electron-builder/**"
    ]
  },
  "devDependencies": {
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "cloudinary": "^2.9.0"
  }
}